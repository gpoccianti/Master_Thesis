\@writefile{lof}{\contentsline {figure}{\numberline {1.6}{\ignorespaces System identification of the diffusion coefficients. The network accurately discovers both $D_V = 0.01$ (left) and $D_w = 0.0$ (right) in less than 5 epochs.}}{23}{figure.caption.21}\protected@file@percent }
\newlabel{fig:lfno_diffusion}{{1.6}{23}{System identification of the diffusion coefficients. The network accurately discovers both $D_V = 0.01$ (left) and $D_w = 0.0$ (right) in less than 5 epochs}{figure.caption.21}{}}
